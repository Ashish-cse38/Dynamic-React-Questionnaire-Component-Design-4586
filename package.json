{
  "name": "dynamic-react-questionnare-component",
  "private": false,
  "version": "0.1.0",
  "description": "A dynamic, JSON-driven multi-step questionnaire component for React with built-in validation, smooth animations, and a progress indicator.",
  "license": "MIT",
  "author": "questionnaire-react contributors",
  "keywords": [
    "react",
    "questionnaire",
    "form",
    "multi-step",
    "wizard",
    "survey",
    "json-driven",
    "framer-motion",
    "tailwindcss",
    "validation",
    "progress-bar",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/dynamic-react-questionnare-component.git"
  },
  "homepage": "https://github.com/your-org/dynamic-react-questionnare-component#readme",
  "bugs": {
    "url": "https://github.com/your-org/dynamic-react-questionnare-component/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "lint": "eslint .",
    "lint:error": "eslint . --quiet",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "framer-motion": "^11.0.8",
    "react-icons": "^5.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20",
    "react-dom": ">=18.0.0 <20"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
